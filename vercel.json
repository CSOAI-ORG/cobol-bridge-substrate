{
    "version": 2,
    "builds": [
        { "src": "server.js", "use": "@vercel/node" },
        { "src": "*.html", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/health", "dest": "server.js" },
        { "src": "/mcp", "dest": "server.js" },
        { "src": "/platform$", "dest": "/platform.html" },
        { "src": "/about$", "dest": "/about.html" },
        { "src": "/sectors$", "dest": "/sectors.html" },
        { "src": "/pricing$", "dest": "/pricing.html" },
        { "src": "/docs$", "dest": "/docs.html" },
        { "src": "/contact$", "dest": "/contact.html" },
        { "src": "/banking$", "dest": "/banking.html" },
        { "src": "/government$", "dest": "/government.html" },
        { "src": "/healthcare$", "dest": "/healthcare.html" },
        { "src": "/insurance$", "dest": "/insurance.html" },
        { "src": "/defence$", "dest": "/defence.html" },
        { "src": "/finance$", "dest": "/finance.html" },
        { "src": "/dora-compliance$", "dest": "/dora-compliance.html" },
        { "src": "/ai-explainability$", "dest": "/ai-explainability.html" },
        { "src": "/legacy-modernisation$", "dest": "/legacy-modernisation.html" },
        { "src": "/real-time-payments$", "dest": "/real-time-payments.html" },
        { "src": "/cobol-bridge-express$", "dest": "/cobol-bridge-express.html" },
        { "src": "/products$", "dest": "/products.html" },
        { "src": "/privacy$", "dest": "/index.html" },
        { "src": "/terms$", "dest": "/index.html" },
        { "src": "/cookies$", "dest": "/index.html" },
        { "src": "/security$", "dest": "/index.html" },
        { "src": "/assets/(.*)", "dest": "/assets/$1" },
        { "src": "^/$", "dest": "/index.html" }
    ]
}
